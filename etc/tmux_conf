set -g default-terminal "screen-256color"

#set -g terminal-overrides 'xterm*:smcup@:rmcup@'
unbind C-b
set -g prefix C-a
bind C-a send-prefix


setw -g mode-keys vi
set -g base-index 1
set -s escape-time 0
set -g mode-mouse on

bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R


